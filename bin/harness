#!/bin/sh
# Harness runtime shim — dispatches to platform-specific Go binary.
# On missing binary: emit diagnostic on stderr, exit 0 with EMPTY stdout
# so CC hooks treat it as "no decision" (proceed normally) and non-hook
# subcommands (doctor, sync, validate) no-op silently.
# Never print JSON here — we don't know which hook/command is being
# called and emitting the wrong schema breaks the hook protocol.

# Git Bash/MSYS/Cygwin already tells us this is Windows. Hooks invoke this
# shim by its plugin path, so prefer the shipped native binary before running
# dirname/readlink/uname/tr. If the adjacent binary is unavailable (for
# example when the shim is reached through a PATH symlink), keep the portable
# resolver below as the compatibility path.
WINDOWS_HINT="${OSTYPE:-}:${MSYSTEM:-}:${OS:-}"
case "$WINDOWS_HINT" in
  mingw*:*:*|msys*:*:*|cygwin*:*:*|*:MINGW*:*|*:MSYS*:*|*:CLANG*:*|*:*:Windows_NT)
    case "$0" in
      */*) FAST_SCRIPT_DIR=${0%/*} ;;
      *) FAST_SCRIPT_DIR=. ;;
    esac
    FAST_WINDOWS_BINARY="${FAST_SCRIPT_DIR}/harness-windows-amd64.exe"
    if [ ! -L "$0" ] && [ -x "$FAST_WINDOWS_BINARY" ]; then
      exec "$FAST_WINDOWS_BINARY" "$@"
    fi
    ;;
esac

SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="${SCRIPT_DIR}/${LINK_TARGET}" ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

RAW_OS="$(uname -s | tr A-Z a-z)"
EXT=""
case "$RAW_OS" in
  darwin*) OS="darwin" ;;
  linux*) OS="linux" ;;
  mingw*|msys*|cygwin*) OS="windows"; EXT=".exe" ;;
  *) OS="$RAW_OS" ;;
esac
ARCH="$(uname -m)"
case "$ARCH" in
  x86_64)  ARCH="amd64" ;;
  aarch64) ARCH="arm64" ;;
  arm64)   ARCH="arm64" ;;
esac
BINARY="${SCRIPT_DIR}/harness-${OS}-${ARCH}${EXT}"
if [ -x "$BINARY" ]; then
  exec "$BINARY" "$@"
fi

printf 'claude-code-harness: no binary for %s-%s at %s (command %s skipped).\n' \
  "$OS" "$ARCH" "$BINARY" "${1:-<none>}" >&2
exit 0
