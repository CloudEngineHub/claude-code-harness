{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.local/schemas/bridge-event.v1.json",
  "title": "bridge-event.v1",
  "description": "Normalized bridge envelope for CC Mailbox, Cursor stop hook, and Codex app-server source events.",
  "type": "object",
  "required": [
    "source",
    "event_type",
    "payload",
    "ts"
  ],
  "additionalProperties": false,
  "properties": {
    "source": {
      "type": "string",
      "enum": [
        "cc",
        "cursor",
        "codex"
      ]
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    },
    "ts": {
      "type": "integer"
    }
  }
}
